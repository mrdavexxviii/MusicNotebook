<Window x:Class="MusicNotebook.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusicNotebook"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"   
        Height="{Binding AppStartHeight, Source={StaticResource ssp}}"
        Width="{Binding AppStartWidth, Source={StaticResource ssp}}"
        Left="{Binding HorizontalMargin, Source={StaticResource ssp}}"
        Top="{Binding VerticalMargin, Source={StaticResource ssp}}">

    <Window.Resources>
        <local:BackgroundPicker x:Key="BackgroundPicker" />
        <local:ResourceImageConverter x:Key="ResourceImageConverter" />
        <local:ImageSourceSizeConverter x:Key="ImageSizeConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <DataTemplate x:Key="TextPageTemplate">
            <Grid>
                <TextBox Text="{Binding Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" x:Name="TextPageContent" FontFamily="Consolas" />
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="ImagePageTemplate">
            <Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.Background>
                            <ImageBrush
                                ImageSource="{Binding Background, Converter={StaticResource ResourceImageConverter}}"
                                TileMode="Tile"
                                Viewport="{Binding BackgroundPitch, Converter={StaticResource ImageSizeConverter}}"
                                ViewportUnits="Absolute"
                                Stretch="None"
                                AlignmentY="Bottom"
                                Opacity="0.3" />
                        </Grid.Background>
                        <InkCanvas x:Name="Canvas" Background="Transparent" Strokes="{Binding ImageData}" PreviewStylusDown="Canvas_PreviewStylusDown" PreviewStylusButtonDown="Canvas_PreviewStylusButtonDown" PreviewStylusButtonUp="Canvas_PreviewStylusButtonUp" PreviewMouseLeftButtonDown="Canvas_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="Canvas_PreviewMouseLeftButtonUp" />
                    </Grid>
                </ScrollViewer>
                <Grid HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="5" Height="25" Width="100" x:Name="ImagePanelProperties"
                      Visibility="{Binding DataContext.DisplayProperties, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}">

                    <ComboBox x:Name="BackgroundSelector"
                          ItemsSource="{Binding Source={StaticResource BackgroundPicker}, Path=AvailableBackgrounds}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Resource"
                          SelectedValue="{Binding Background, Mode=TwoWay}"
                          SelectedItem="{Binding SelectedBackground, Mode=TwoWay}" />
                </Grid>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="TitlePageTemplate">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBox BorderBrush="Transparent" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="5" Grid.Row="0" />
                <TextBox Text="{Binding Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Margin="5" Grid.Row="1" />
                <Label Content="Production Notes" HorizontalAlignment="Center" Margin="5" Grid.Row="2" />
                <TextBox Text="{Binding ProductionNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Grid.Row="3" Margin="5" />
            </Grid>
        </DataTemplate>
        <local:TabContentSelector x:Key="TabContentSelector" />

        <!-- New style: constrains the header area (left strip), makes it scrollable,
             and places small Add/Delete buttons at the bottom-right of the header area.
             Buttons bind to the window DataContext commands so they work while the TabControl's
             DataContext is set to NoteBook (as in the UI). -->
        <Style x:Key="LeftTabControlStyle" TargetType="TabControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.ColumnDefinitions>
                                <!-- Fixed/limited header column -->
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Header area: scrollable list of tab headers and buttons at bottom -->
                            <Border Grid.Column="0" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">
                                <DockPanel LastChildFill="True">

                                    <!-- Buttons area pinned to bottom-right of the header column -->
                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Left" Margin="4">
                                        <!-- Bind to Window.DataContext commands explicitly since TabControl inherits NoteBook as DataContext -->
                                        <Button Width="20" Height="20" Padding="0" Margin="0" Background="Transparent" BorderBrush="Transparent"
                                            Command="{Binding DataContext.AddTextPageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            ToolTip="{x:Static local:Resources.PageButton_AddText_Tooltip}">
                                            <Image Width="16" Height="16"
                                                Source="{Binding Source='PageButton_AddText', Converter={StaticResource ResourceImageConverter}}"
                                                Stretch="Uniform" />
                                        </Button>
                                        <Button Width="20" Height="20" Padding="0" Margin="4,0,0,0" Background="Transparent" BorderBrush="Transparent"
                                                Command="{Binding DataContext.AddImagePageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                ToolTip="{x:Static local:Resources.PageButton_AddImage_Tooltip}">
                                            <Image Width="16" Height="16"
                                                Source="{Binding Source='PageButton_AddImage', Converter={StaticResource ResourceImageConverter}}"
                                                Stretch="Uniform" />
                                        </Button>
                                        <Button Width="20" Height="20" Padding="0" Margin="4,0,0,0" Background="Transparent" BorderBrush="Transparent"
                                                Command="{Binding DataContext.DeleteCurrentPageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                ToolTip="{x:Static local:Resources.PageButton_Delete_Tooltip}">
                                            <Image Width="16" Height="16"
                                                Source="{Binding Source='PageButton_Delete', Converter={StaticResource ResourceImageConverter}}"
                                                Stretch="Uniform" />
                                        </Button>
                                    </StackPanel>
                                    <!-- Scrollable TabPanel (headers) -->
                                    <ScrollViewer DockPanel.Dock="Bottom"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  CanContentScroll="True">
                                        <!-- TabPanel is the items host for TabItem headers -->
                                        <TabPanel IsItemsHost="True" Margin="0" />
                                    </ScrollViewer>

                                </DockPanel>
                            </Border>

                            <!-- Content presenter for selected page -->
                            <ContentPresenter Grid.Column="1"
                                              ContentSource="SelectedContent"
                                              ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                              Margin="{TemplateBinding Padding}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="20" />
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Row="0">
            <Button Content="New" Command="{Binding NewCommand}" Width="50" />
            <Button Content="Save" Command="{Binding SaveCommand}" Width="50" />
            <Button Content="Save As" Command="{Binding SaveAsCommand}" Width="50" />
            <Button Content="Open" Command="{Binding OpenCommand}" Width="50" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Row="0" HorizontalAlignment="Right">
            <ToggleButton HorizontalAlignment="Right" Content="Properties" Width="80" IsChecked="{Binding DisplayProperties}" />
        </StackPanel>
        <Grid x:Name="ContentGrid" DataContext="{Binding NoteBook}" Grid.Row="1">
            <!-- Apply the new style to constrain header area and add scrolling -->
            <TabControl Style="{StaticResource LeftTabControlStyle}"
                        ItemsSource="{Binding Pages}"
                        SelectedItem="{Binding SelectedPage, Mode=TwoWay}"
                        ContentTemplateSelector="{StaticResource TabContentSelector}"
                        x:Name="Tabs"
                        TabStripPlacement="Left">
                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem">
                        <Setter Property="HeaderTemplate">
                            <Setter.Value>
                                <DataTemplate>
                                    <Grid Width="100" x:Name="TabTitleContainer">
                                        <!-- Read-only title shown by default -->
                                        <Label x:Name="TabTitleLabel"
                                               Content="{Binding Name}"
                                               VerticalAlignment="Center"
                                               Padding="4"
                                               MouseDoubleClick="TabTitleLabel_MouseDoubleClick"/>
                                        <!-- Editor hidden by default -->
                                        <TextBox x:Name="TabTitleEditor"
                                                 Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Visibility="Collapsed"
                                                 VerticalAlignment="Center"
                                                 Padding="2"
                                                 MinWidth="80"
                                                 LostFocus="TabTitleEditor_LostFocus"
                                                 KeyDown="TabTitleEditor_KeyDown"/>
                                    </Grid>
                                </DataTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.ItemContainerStyle>
            </TabControl>
        </Grid>
    </Grid>
</Window>